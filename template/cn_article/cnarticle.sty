\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cnarticle}[2026/05/31 Chinese course report style]

% =========================================================
% 编译与基础宏包
% =========================================================
\RequirePackage{iftex}
\ifPDFTeX
  \errmessage{Please compile with XeLaTeX or LuaLaTeX}
\fi

\RequirePackage[fontset=fandol]{ctex}
\RequirePackage{fontspec}
\RequirePackage{geometry}
\RequirePackage{xcolor}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage{titlesec}
\RequirePackage{fancyhdr}
\RequirePackage{tikz}
\usetikzlibrary{positioning}
\RequirePackage[most]{tcolorbox}
\RequirePackage{amsmath,amssymb,amsthm,mathtools,bm}
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage[capitalize,nameinlink]{cleveref}

% =========================================================
% 页面尺寸与正文节奏
% 课程报告默认使用 A4 与常规页边距，避免 lecture handout 的窄页感。
% =========================================================
\geometry{
  a4paper,
  left=2.65cm,
  right=2.65cm,
  top=2.55cm,
  bottom=2.65cm,
  headsep=0.55cm,
  footskip=0.9cm
}

\linespread{1.22}
\setlength{\parindent}{2em}
\setlength{\parskip}{0.18em}

% =========================================================
% 字体配置
% 优先使用系统常见字体；缺失时回退到 TeX 发行版自带字体。
% =========================================================
\IfFontExistsTF{Times New Roman}
  {\setmainfont{Times New Roman}}
  {\setmainfont{TeX Gyre Termes}}
\IfFontExistsTF{Helvetica Neue}
  {\setsansfont{Helvetica Neue}}
  {\setsansfont{TeX Gyre Heros}}
\IfFontExistsTF{JetBrains Mono}
  {\setmonofont{JetBrains Mono}}
  {\IfFontExistsTF{FiraCode Nerd Font}
    {\setmonofont{FiraCode Nerd Font}}
    {\setmonofont{Courier New}}}
\IfFontExistsTF{Noto Serif CJK SC}{\setCJKmainfont{Noto Serif CJK SC}}{}
\IfFontExistsTF{Noto Sans CJK SC}{\setCJKsansfont{Noto Sans CJK SC}}{}

% =========================================================
% 色彩系统
% 由 lecture 风格的高饱和蓝色调整为更克制的报告蓝灰色系。
% =========================================================
\definecolor{reportNavy}{HTML}{243B53}
\definecolor{reportBlue}{HTML}{2F6F9F}
\definecolor{reportBlueD}{HTML}{1F4E79}
\definecolor{reportTeal}{HTML}{2A9D8F}
\definecolor{reportTealD}{HTML}{1F7A70}
\definecolor{reportGold}{HTML}{C78C22}
\definecolor{reportRed}{HTML}{C8553D}
\definecolor{ink}{HTML}{1F2933}
\definecolor{muted}{HTML}{66788A}
\definecolor{linegray}{HTML}{D8E0E8}
\definecolor{paperSoft}{HTML}{F7FAFC}
\definecolor{blueSoft}{HTML}{EEF6FC}
\definecolor{tealSoft}{HTML}{EEF8F6}
\definecolor{goldSoft}{HTML}{FFF8EA}
\definecolor{redSoft}{HTML}{FFF1EF}

% 兼容旧正文中的颜色名，方便逐步迁移已有内容。
\colorlet{brand}{reportBlue}
\colorlet{brandD}{reportBlueD}
\colorlet{themegreen}{reportTeal}
\colorlet{themegreenD}{reportTealD}
\colorlet{keybg}{blueSoft}
\colorlet{keydark}{reportNavy}
\colorlet{accent}{reportGold}
\colorlet{accentD}{reportGold}
\colorlet{soft}{goldSoft}
\colorlet{xhsRed}{reportRed}
\colorlet{xhsDark}{ink}
\colorlet{xhsCream}{paperSoft}
\colorlet{xhsBlue}{reportBlue}
\colorlet{xhsYellow}{reportGold}
\colorlet{secblue}{reportBlueD}
\colorlet{thmBg}{blueSoft}
\colorlet{lemBg}{redSoft}
\colorlet{defBg}{tealSoft}

% =========================================================
% PDF 与链接样式
% =========================================================
\hypersetup{
  colorlinks=true,
  linkcolor=reportBlueD,
  citecolor=reportBlueD,
  urlcolor=reportBlue,
  pdfauthor={MIStatlE},
  pdftitle={Course Report}
}

% =========================================================
% 编号规则
% 报告采用普通 article 编号：1, 1.1, 公式按节编号。
% =========================================================
\numberwithin{equation}{section}
\renewcommand{\theequation}{\thesection.\arabic{equation}}

\titleformat{\section}
  {\Large\bfseries\color{reportNavy}}
  {\thesection}{0.6em}{}
\titlespacing*{\section}{0pt}{1.2em}{0.55em}

\titleformat{\subsection}
  {\large\bfseries\color{reportBlueD}}
  {\thesubsection}{0.55em}{}
\titlespacing*{\subsection}{0pt}{0.9em}{0.35em}

\setlist[itemize]{leftmargin=1.7em,itemsep=0.22em,topsep=0.4em}
\setlist[enumerate]{leftmargin=1.9em,itemsep=0.22em,topsep=0.4em}

% =========================================================
% 报告元信息与页眉页脚
% 在 main.tex 中用 \CourseReportInfo 填写课程、学期、题目等信息。
% =========================================================
\makeatletter
\newcommand{\cnreport@course}{Course Report}
\newcommand{\cnreport@term}{}
\newcommand{\cnreport@title}{Untitled Report}
\newcommand{\cnreport@subtitle}{}
\newcommand{\cnreport@author}{}
\newcommand{\cnreport@affiliation}{}

\newcommand{\CourseReportInfo}[6]{%
  \renewcommand{\cnreport@course}{#1}%
  \renewcommand{\cnreport@term}{#2}%
  \renewcommand{\cnreport@title}{#3}%
  \renewcommand{\cnreport@subtitle}{#4}%
  \renewcommand{\cnreport@author}{#5}%
  \renewcommand{\cnreport@affiliation}{#6}%
  \hypersetup{pdfauthor={#5},pdftitle={#3}}%
}

\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{\small\sffamily\color{reportBlueD}\cnreport@course}
\fancyhead[R]{\small\sffamily\color{ink}\nouppercase{\rightmark}}
\fancyfoot[L]{\small\sffamily\color{muted}\cnreport@author}
\fancyfoot[R]{\small\sffamily\color{reportBlueD}\thepage}
\pagestyle{fancy}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[R]{\small\sffamily\color{reportBlueD}\thepage}%
}
\renewcommand{\sectionmark}[1]{\markright{#1}}

% =========================================================
% 标题区
% 这是课程报告的首页标题块，替代原来的 lecture banner。
% =========================================================
\newcommand{\MakeCourseReportTitle}{%
  \thispagestyle{plain}%
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=white,
    colframe=linegray,
    boxrule=0.7pt,
    arc=3pt,
    left=14pt,right=14pt,top=14pt,bottom=14pt,
    borderline west={4pt}{0pt}{reportBlueD}
  ]
    {\sffamily\small\color{muted}\cnreport@course
      \hfill \cnreport@term\par}
    \vspace{0.65em}
    {\bfseries\fontsize{24}{30}\selectfont\color{reportNavy}\cnreport@title\par}
    \if\relax\detokenize\expandafter{\cnreport@subtitle}\relax
    \else
      \vspace{0.25em}
      {\large\color{reportBlueD}\cnreport@subtitle\par}
    \fi
    \vspace{0.9em}
    {\small\sffamily\color{ink!75}
      作者：\cnreport@author
      \hfill
      {\color{muted}\cnreport@affiliation}\par}
  \end{tcolorbox}
  \vspace{0.75em}
}

% 兼容旧模板入口：旧的 \LectureBanner 会被渲染成报告标题块。
\newcommand{\LectureBanner}[6]{%
  \CourseReportInfo{#4}{#5}{#2}{#3}{#6}{\cnreport@affiliation}%
  \MakeCourseReportTitle
}
\makeatother

% =========================================================
% tcolorbox 基础样式
% cn-panel 用于完整边框信息块；cn-soft 用于左侧强调线信息块。
% =========================================================
\tcbset{
  cn-panel/.style={
    enhanced,
    breakable,
    boxrule=0.7pt,
    arc=3pt,
    left=10pt,right=10pt,top=10pt,bottom=10pt
  },
  cn-soft/.style={
    enhanced,
    breakable,
    frame hidden,
    borderline west={3pt}{0pt}{#1},
    colback=#1!7,
    left=9pt,right=9pt,top=8pt,bottom=8pt,
    arc=2pt
  }
}

% =========================================================
% 常用报告信息块
% =========================================================
\newtcolorbox{SummaryBox}{
  cn-panel,
  colback=paperSoft,
  colframe=reportBlueD,
  title=\textbf{报告摘要},
  fonttitle=\bfseries,
  coltitle=white,
  colbacktitle=reportBlueD
}

\newtcolorbox{AnalysisBox}{
  cn-soft=reportBlue,
  title=\textbf{分析},
  fonttitle=\bfseries,
  coltitle=reportBlueD
}

\newtcolorbox{RemarkBox}{
  cn-soft=reportGold,
  title=\textbf{备注},
  fonttitle=\bfseries,
  coltitle=reportGold
}

\newtcolorbox{ExampleBox}{
  cn-panel,
  colback=white,
  colframe=reportTealD,
  title=\textbf{示例},
  fonttitle=\bfseries,
  coltitle=white,
  colbacktitle=reportTealD
}

% =========================================================
% 定理环境
% =========================================================
\theoremstyle{plain}
\newtheorem{theorem}{定理}[section]
\newtheorem{lemma}[theorem]{引理}
\newtheorem{proposition}[theorem]{命题}
\newtheorem{corollary}[theorem]{推论}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{定义}
\theoremstyle{remark}
\newtheorem{remark}[theorem]{注}

\tcolorboxenvironment{theorem}{cn-panel,colback=blueSoft,colframe=reportBlueD,borderline west={3pt}{0pt}{reportBlueD}}
\tcolorboxenvironment{lemma}{cn-panel,colback=redSoft,colframe=reportRed,borderline west={3pt}{0pt}{reportRed}}
\tcolorboxenvironment{proposition}{cn-panel,colback=blueSoft,colframe=reportBlue,borderline west={3pt}{0pt}{reportBlue}}
\tcolorboxenvironment{corollary}{cn-panel,colback=blueSoft,colframe=reportTealD,borderline west={3pt}{0pt}{reportTealD}}
\tcolorboxenvironment{definition}{cn-panel,colback=tealSoft,colframe=reportTealD,borderline west={3pt}{0pt}{reportTealD}}
\tcolorboxenvironment{remark}{cn-soft=reportGold,title=\textbf{注},fonttitle=\bfseries,coltitle=reportGold}

% =========================================================
% 数学快捷命令
% =========================================================
\newcommand{\dd}{\,\mathrm{d}}      % 微分算子
\newcommand{\tran}{^{\top}}         % 转置
\newcommand{\E}{\mathbb{E}}         % 期望
\newcommand{\D}{\mathbb{D}}         % 常用黑板粗体 D
\newcommand{\R}{\mathbb{R}}         % 实数域

\DeclareMathOperator{\diam}{diam}
\DeclareMathOperator{\Var}{Var}
\DeclareMathOperator{\Cov}{Cov}
\DeclareMathOperator{\diag}{diag}

\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiterX{\ip}[2]{\langle}{\rangle}{#1, #2}